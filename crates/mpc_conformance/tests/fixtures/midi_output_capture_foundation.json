{
  "id": "core.midi-output.capture-foundation",
  "name": "Physical pad playback emits deterministic MIDI output intent for host capture",
  "source_refs": [
    "docs/superpowers/plans/2026-06-14-mpc2000xl-midi-output-capture-foundation.md#behavior-slice",
    "docs/superpowers/plans/2026-06-14-mpc2000xl-midi-device-io-foundation.md#deterministic-contract",
    "docs/evidence/behavior-matrix.json#core.midi-output.capture-foundation",
    "docs/evidence/behavior-matrix.json#host.midi.device-io-foundation"
  ],
  "events": [
    {
      "type": "strike_pad",
      "bank": "b",
      "pad": 4,
      "velocity": 84
    }
  ],
  "host_midi": {
    "enabled": true,
    "retained_message_capacity": 4,
    "input_decode_cases": [
      {
        "name": "note_on_bytes",
        "bytes": [
          144,
          55,
          84
        ],
        "expect_event": {
          "type": "note_on",
          "channel": 1,
          "note": 55,
          "velocity": 84
        }
      },
      {
        "name": "note_off_bytes",
        "bytes": [
          128,
          55,
          64
        ],
        "expect_event": {
          "type": "note_off",
          "channel": 1,
          "note": 55,
          "velocity": 64
        }
      },
      {
        "name": "note_on_velocity_zero_is_note_off",
        "bytes": [
          144,
          55,
          0
        ],
        "expect_event": {
          "type": "note_off",
          "channel": 1,
          "note": 55,
          "velocity": 0
        }
      },
      {
        "name": "unsupported_control_change_is_ignored",
        "bytes": [
          176,
          1,
          64
        ],
        "expect_ignored": true
      },
      {
        "name": "short_note_message_errors",
        "bytes": [
          144,
          55
        ],
        "expect_error_contains": "short MIDI note message"
      }
    ],
    "expect": {
      "mode": "capture",
      "backend_name": "capture",
      "queued_message_count": 1,
      "ignored_message_count": 0,
      "failed_message_count": 0,
      "backend_total_sent_count": 1,
      "capture_count": 1,
      "captured_messages": [
        {
          "channel": 1,
          "note": 55,
          "velocity": 84
        }
      ],
      "captured_encoded_note_on_bytes": [
        [
          144,
          55,
          84
        ]
      ],
      "last_event_type": "queued",
      "last_event_message": {
        "channel": 1,
        "note": 55,
        "velocity": 84
      },
      "last_event_backend_receipt_message_count": 1
    }
  },
  "expect_output_sequence": [
    {
      "type": "pad_triggered",
      "bank": "b",
      "pad": 4,
      "velocity": 84
    },
    {
      "type": "sample_playback_intent",
      "intent": {
        "selected_track": 1,
        "program_index": 1,
        "program_name": "Program01",
        "bank": "b",
        "pad_number": 4,
        "sample_id": "synthetic_b_04",
        "sample_name": "SYN-B04",
        "velocity": 84,
        "level": 100,
        "pan": 0,
        "tune_cents": 0
      }
    },
    {
      "type": "midi_output_intent",
      "intent": {
        "selected_track": 1,
        "program_index": 1,
        "program_name": "Program01",
        "bank": "b",
        "pad_number": 4,
        "source_sample_id": "synthetic_b_04",
        "source_sample_name": "SYN-B04",
        "channel": 1,
        "note": 55,
        "velocity": 84
      }
    }
  ],
  "expect": {
    "mode": "main",
    "lcd_title": "MAIN",
    "playing": false,
    "recording": false,
    "event_count": 1,
    "selected_track": 1,
    "pad_bank": "b",
    "current_program_index": 1,
    "current_program_name": "Program01",
    "pad_assignment_count": 64,
    "midi_base_note": 36,
    "midi_mapped_note_range": [
      36,
      51
    ],
    "last_playback": {
      "type": "intent",
      "intent": {
        "selected_track": 1,
        "program_index": 1,
        "program_name": "Program01",
        "bank": "b",
        "pad_number": 4,
        "sample_id": "synthetic_b_04",
        "sample_name": "SYN-B04",
        "velocity": 84,
        "level": 100,
        "pan": 0,
        "tune_cents": 0
      }
    }
  }
}
