{
  "id": "storage.project.file-save-load.restore-validation",
  "name": "Project file save/load restores synthetic metadata and validates invalid project JSON",
  "source_refs": [
    "docs/superpowers/plans/2026-06-13-mpc2000xl-project-file-storage.md#source-and-evidence-status",
    "docs/superpowers/plans/2026-06-13-mpc2000xl-project-persistence.md#validation",
    "docs/evidence/behavior-matrix.json#storage.project.file-save-load",
    "docs/evidence/behavior-matrix.json#core.project.restore-validation"
  ],
  "events": [
    {
      "type": "press",
      "control": "program"
    },
    {
      "type": "strike_pad",
      "bank": "a",
      "pad": 3,
      "velocity": 90
    },
    {
      "type": "press",
      "control": "rec"
    },
    {
      "type": "press",
      "control": "play"
    },
    {
      "type": "tick",
      "micros": 500000
    },
    {
      "type": "strike_pad",
      "bank": "a",
      "pad": 3,
      "velocity": 77
    }
  ],
  "expect": {
    "mode": "program",
    "lcd_title": "PROGRAM",
    "playing": true,
    "recording": true,
    "event_count": 6,
    "selected_track": 1,
    "recorded_event_count": 1,
    "playhead_ticks": 96,
    "current_program_index": 1,
    "current_program_name": "Program01",
    "pad_assignment_count": 64,
    "selected_program_pad": {
      "bank": "a",
      "pad_number": 3
    },
    "last_recorded_sample_id": "synthetic_a_03",
    "last_recorded_sample_name": "SYN-A03",
    "last_playback": {
      "type": "intent",
      "intent": {
        "selected_track": 1,
        "program_index": 1,
        "program_name": "Program01",
        "bank": "a",
        "pad_number": 3,
        "sample_id": "synthetic_a_03",
        "sample_name": "SYN-A03",
        "velocity": 77,
        "level": 100,
        "pan": 0,
        "tune_cents": 0
      }
    },
    "last_recorded_event": {
      "selected_track": 1,
      "pad_bank": "a",
      "pad_number": 3,
      "velocity": 77,
      "tick": 96,
      "playback": {
        "selected_track": 1,
        "program_index": 1,
        "program_name": "Program01",
        "bank": "a",
        "pad_number": 3,
        "sample_id": "synthetic_a_03",
        "sample_name": "SYN-A03",
        "velocity": 77,
        "level": 100,
        "pan": 0,
        "tune_cents": 0
      }
    }
  },
  "project_round_trip": {
    "expect_snapshot_version": 1,
    "project_file_round_trip": true,
    "invalid_project_json_cases": [
      {
        "name": "unsupported_version",
        "mutation": {
          "type": "unsupported_version",
          "version": 99
        },
        "expect_error_contains": "unsupported project snapshot version 99"
      },
      {
        "name": "invalid_rights_boundary",
        "mutation": {
          "type": "invalid_rights_boundary",
          "rights_boundary": "contains_audio_bytes"
        },
        "expect_error_contains": "invalid project rights boundary"
      },
      {
        "name": "duplicate_first_pad_assignment",
        "mutation": {
          "type": "duplicate_first_pad_assignment"
        },
        "expect_error_contains": "duplicate project pad assignment"
      },
      {
        "name": "unknown_root_audio_bytes",
        "mutation": {
          "type": "unknown_root_field",
          "field": "audio_bytes"
        },
        "expect_error_contains": "audio_bytes"
      },
      {
        "name": "event_count_less_than_recorded_events",
        "mutation": {
          "type": "event_count_less_than_recorded_events"
        },
        "expect_error_contains": "machine.event_count"
      },
      {
        "name": "last_playback_with_zero_event_count",
        "mutation": {
          "type": "last_playback_with_zero_event_count"
        },
        "expect_error_contains": "machine.last_playback"
      }
    ],
    "post_restore_events": [
      {
        "type": "strike_pad",
        "bank": "a",
        "pad": 3,
        "velocity": 99
      }
    ],
    "expect": {
      "mode": "program",
      "lcd_title": "PROGRAM",
      "playing": false,
      "recording": false,
      "event_count": 7,
      "selected_track": 1,
      "recorded_event_count": 1,
      "playhead_ticks": 96,
      "current_program_index": 1,
      "current_program_name": "Program01",
      "pad_assignment_count": 64,
      "selected_program_pad": {
        "bank": "a",
        "pad_number": 3
      },
      "last_recorded_sample_id": "synthetic_a_03",
      "last_recorded_sample_name": "SYN-A03",
      "last_playback": {
        "type": "intent",
        "intent": {
          "selected_track": 1,
          "program_index": 1,
          "program_name": "Program01",
          "bank": "a",
          "pad_number": 3,
          "sample_id": "synthetic_a_03",
          "sample_name": "SYN-A03",
          "velocity": 99,
          "level": 100,
          "pan": 0,
          "tune_cents": 0
        }
      },
      "last_recorded_event": {
        "selected_track": 1,
        "pad_bank": "a",
        "pad_number": 3,
        "velocity": 77,
        "tick": 96,
        "playback": {
          "selected_track": 1,
          "program_index": 1,
          "program_name": "Program01",
          "bank": "a",
          "pad_number": 3,
          "sample_id": "synthetic_a_03",
          "sample_name": "SYN-A03",
          "velocity": 77,
          "level": 100,
          "pan": 0,
          "tune_cents": 0
        }
      }
    }
  }
}
